OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
API_KEY=seguridad-dashboard-123
PORT=3000

# Claude como motor del chat() (Sonnet en pasos premium, Haiku en el resto) en vez
# de GPT-4o. Si CLAUDE_AB_SELLERS está vacío o falta ANTHROPIC_API_KEY, queda OFF
# (todo en OpenAI). CLAUDE_AB_SELLERS: lista de sellers (coma-separados) o '*' para
# TODOS (migración full, incluye sellers futuros). CLAUDE_AB_PERCENT = % de las
# conversaciones que van a Claude (split determinista por teléfono; 100 = todas).
# Whisper, embeddings y visión siguen SIEMPRE en OpenAI (Anthropic no los tiene).
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# CLAUDE_AB_SELLERS=*
# CLAUDE_AB_PERCENT=100
# CLAUDE_MODEL_PREMIUM=claude-sonnet-4-6
# CLAUDE_MODEL_SIMPLE=claude-haiku-4-5-20251001

# Tope mensual de gasto de IA (USD). El scheduler acumula el costo del mes en
# DATA_DIR/ai-cost-<YYYY-MM>.json y alerta al admin al 80% y 100% del tope.
# 0 = desactivar el guardián. Default 500.
# AI_MONTHLY_BUDGET_USD=500

# JWT Auth (multi-tenant)
JWT_SECRET=your_jwt_secret_64chars_min
SEED_ADMIN_EMAIL=admin@tudominio.com
SEED_ADMIN_PASSWORD=your_admin_password_here

# Railway / Production
# DATA_DIR=/data
# VITE_API_KEY=your-api-key-here
# GOOGLE_SHEET_ID=your-sheet-id
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ElevenLabs TTS
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
