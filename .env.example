OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
API_KEY=seguridad-dashboard-123
PORT=3000

# A/B Claude (experimento). El chat() corre sobre Claude (Sonnet en pasos premium,
# Haiku en el resto) en vez de GPT-4o. Si CLAUDE_AB_SELLERS está vacío o falta
# ANTHROPIC_API_KEY, queda OFF (todo en OpenAI). CLAUDE_AB_PERCENT = % de las
# conversaciones de ese seller que van a Claude (split determinista por teléfono,
# DENTRO del seller — para A/B sobre el mismo tráfico cuando un solo seller vende).
# Whisper, embeddings y visión siguen SIEMPRE en OpenAI (Anthropic no los tiene).
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# CLAUDE_AB_SELLERS=horacio
# CLAUDE_AB_PERCENT=50
# CLAUDE_MODEL_PREMIUM=claude-sonnet-4-6
# CLAUDE_MODEL_SIMPLE=claude-haiku-4-5-20251001

# JWT Auth (multi-tenant)
JWT_SECRET=your_jwt_secret_64chars_min
SEED_ADMIN_EMAIL=admin@tudominio.com
SEED_ADMIN_PASSWORD=your_admin_password_here

# Railway / Production
# DATA_DIR=/data
# VITE_API_KEY=your-api-key-here
# GOOGLE_SHEET_ID=your-sheet-id
