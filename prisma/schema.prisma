generator client {
  provider = "prisma-client-js"
}

// Para desarrollo local podemos usar SQLite para probar, pero luego Postgres.
// Dado que la app ya usa Railway y pide Postgres, usaremos postgresql.
datasource db {
  provider = "postgresql"
}

model User {
  phone       String
  instanceId  String   @default("default")
  name        String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now()) // Updated every time the user sends a message
  profileData String?  // Extracted by AI (e.g., weight goals, allergies)
  pausedAt    DateTime? // Set when bot auto-pauses this user
  pauseReason String?   // Human-readable reason for the pause

  orders      Order[]
  chats       ChatLog[]

  @@id([phone, instanceId])
}

model Order {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId], onDelete: Cascade)

  status      String   @default("Pendiente") // Pendiente, Confirmado, Enviado...
  products    String   // List of products bought
  totalPrice  Float
  tracking    String?
  postdated   String?
  seller      String?  // Phone number of the WhatsApp session that created the order

  nombre      String?
  calle       String?
  calleOriginal String?  // Raw address as typed by the client (before Maps formatting)
  ciudad      String?
  provincia   String?
  cp          String?

  createdAt   DateTime @default(now())

  @@index([userPhone, instanceId])
  @@index([instanceId])
  @@index([createdAt])
}

model ChatLog {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId], onDelete: Cascade)

  role        String   // "user" or "bot" or "system"
  content     String

  timestamp   DateTime @default(now())

  @@index([userPhone, instanceId])
  @@index([userPhone, instanceId, timestamp])
  @@index([timestamp])
}

model BotConfig {
  instanceId  String   @default("default")
  key         String   // e.g. "activeScript", "alertNumbers"
  value       String   // JSON stringified value

  @@id([instanceId, key])
}

model PaymentLink {
  id             String    @id @default(uuid())
  instanceId     String    @default("default")
  preferenceId   String    @unique
  externalRef    String    @unique
  amount         Float
  status         String    @default("pending") // pending | approved | rejected | expired
  link           String
  userPhone      String?
  sellerPhone    String?
  source         String    @default("dashboard") // "dashboard" | "whatsapp"
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([instanceId])
}

model AiErrorReport {
  id              String   @id @default(uuid())
  instanceId      String   @default("default")
  userPhone       String   // The client's phone number
  reportedMessage String   // The bot message flagged as wrong
  conversation    String   // JSON array of context messages
  correction      String   // Admin's correction/explanation
  createdAt       DateTime @default(now())

  @@index([instanceId])
  @@index([createdAt])
}

model DailyStats {
  id              String   @id @default(uuid())
  instanceId      String   @default("default")
  date            DateTime // Date representing the specific day (e.g. at midnight)

  totalChats      Int      // Encompasses total users/chats in memory before clearing
  completedOrders Int      // Number of completed orders for the day
  totalRevenue    Float    // Total revenue for the day
  stepCounts      String?  // JSON: users per step at snapshot time (funnel analytics)

  createdAt       DateTime @default(now())

  @@unique([instanceId, date])
}

// --- Multi-tenant: Accounts & Sessions ---

model Account {
  id        String   @id @default(uuid())
  name      String   @unique            // "nombre de usuario" — used for login
  password  String   // bcrypt hash
  role      String   @default("seller") // "admin" | "seller"
  sellerId  String?  @unique            // maps to instanceId; null for admin-only accounts
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model WhatsAppSession {
  sellerId    String   @id              // matches instanceId across all tables
  status      String   @default("disconnected") // disconnected | qr_pending | connected
  phoneNumber String?  // connected WhatsApp phone number
  lastSeen    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuickReply {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  title       String
  message     String
  createdAt   DateTime @default(now())

  @@index([instanceId])
  @@unique([instanceId, title])
}

// Semantic cache: stores FAQ-style bot responses keyed by embedding similarity.
// The embedding is persisted as JSON-serialized Float[] in a Text column so
// Postgres native vector support isn't required. Cosine similarity is computed
// in-process over a small per-step candidate window.
model AiSemanticCache {
  id          String   @id @default(uuid())
  step        String   // e.g. "waiting_preference", "waiting_ok"
  userText    String   // raw (lowercased) user message — kept for debug
  embedding   String   // JSON Float[] (1536 dims for text-embedding-3-small)
  response    String   // bot response to serve verbatim
  hits        Int      @default(0)
  createdAt   DateTime @default(now())
  lastHit     DateTime @default(now())

  @@index([step])
  @@index([lastHit])
}
