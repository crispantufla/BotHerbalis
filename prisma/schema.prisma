generator client {
  provider = "prisma-client-js"
}

// Para desarrollo local podemos usar SQLite para probar, pero luego Postgres.
// Dado que la app ya usa Railway y pide Postgres, usaremos postgresql.
datasource db {
  provider = "postgresql"
}

model User {
  phone       String
  instanceId  String   @default("default")
  name        String?
  createdAt   DateTime @default(now())
  profileData String?  // Extracted by AI (e.g., weight goals, allergies)
  pausedAt    DateTime? // Set when bot auto-pauses this user
  pauseReason String?   // Human-readable reason for the pause

  orders      Order[]
  chats       ChatLog[]

  @@id([phone, instanceId])
}

model Order {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId])
  
  status      String   @default("Pendiente") // Pendiente, Confirmado, Enviado...
  products    String   // List of products bought
  totalPrice  Float
  tracking    String?
  postdated   String?
  seller      String?  // Phone number of the WhatsApp session that created the order
  
  nombre      String?
  calle       String?
  ciudad      String?
  provincia   String?
  cp          String?
  
  createdAt   DateTime @default(now())
}

model ChatLog {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId])
  
  role        String   // "user" or "bot" or "system"
  content     String
  
  timestamp   DateTime @default(now())
}

model BotConfig {
  instanceId  String   @default("default")
  key         String   // e.g. "activeScript", "alertNumbers"
  value       String   // JSON stringified value

  @@id([instanceId, key])
}
