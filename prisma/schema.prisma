generator client {
  provider = "prisma-client-js"
}

// Para desarrollo local podemos usar SQLite para probar, pero luego Postgres.
// Dado que la app ya usa Railway y pide Postgres, usaremos postgresql.
datasource db {
  provider = "postgresql"
}

model User {
  phone       String
  instanceId  String   @default("default")
  name        String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now()) // Updated every time the user sends a message
  profileData String?  // Extracted by AI (e.g., weight goals, allergies)
  pausedAt    DateTime? // Set when bot auto-pauses this user
  pauseReason String?   // Human-readable reason for the pause

  orders      Order[]
  chats       ChatLog[]

  @@id([phone, instanceId])
  // Analytics endpoints query users por instance + rango de fechas;
  // sin este índice Postgres tiene que escanear toda la tabla.
  @@index([instanceId, createdAt])
}

model Order {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId], onDelete: Cascade)

  status      String   @default("Pendiente") // Pendiente, Confirmado, Enviado...
  products    String   // List of products bought
  totalPrice  Float
  tracking    String?
  postdated   String?
  seller      String?  // Phone number of the WhatsApp session that created the order
  paymentMethod String? // mercadopago | contrarembolso | transferencia

  // Seña / anticipo para flujo COD (mayo 2026):
  //   senaAmount       = monto del anticipo ya pagado (típicamente $10.000)
  //   senaPaid         = true si la seña fue confirmada (MP approved o transfer)
  //   cashRemainder    = saldo en efectivo que el cartero debe cobrar
  // Si paymentMethod = 'mercadopago' o 'transferencia' con pago completo,
  // estos quedan null/false/null. Si 'contrarembolso' sin seña pagada
  // (situación legacy/manual), también null.
  senaAmount    Int?
  senaPaid      Boolean  @default(false)
  cashRemainder Int?

  nombre      String?
  email       String?  // Optional, captured during MP flow for receipt + payer pre-fill
  calle       String?
  calleOriginal String?  // Raw address as typed by the client (before Maps formatting)
  ciudad      String?
  provincia   String?
  cp          String?

  createdAt   DateTime @default(now())

  @@index([userPhone, instanceId])
  @@index([instanceId])
  @@index([createdAt])
}

model ChatLog {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId], onDelete: Cascade)

  role        String   // "user" or "bot" or "system"
  content     String

  timestamp   DateTime @default(now())

  @@index([userPhone, instanceId])
  @@index([userPhone, instanceId, timestamp])
  @@index([timestamp])
}

model BotConfig {
  instanceId  String   @default("default")
  key         String   // e.g. "activeScript", "alertNumbers"
  value       String   // JSON stringified value

  @@id([instanceId, key])
}

model PaymentLink {
  id             String    @id @default(uuid())
  instanceId     String    @default("default")
  preferenceId   String    @unique
  externalRef    String    @unique
  amount         Float
  status         String    @default("pending") // pending | approved | rejected | expired
  link           String
  userPhone      String?
  sellerPhone    String?
  source         String    @default("dashboard") // "dashboard" | "whatsapp"
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([instanceId])
}

model AiErrorReport {
  id              String   @id @default(uuid())
  instanceId      String   @default("default")
  userPhone       String   // The client's phone number
  reportedMessage String   // The bot message flagged as wrong
  conversation    String   // JSON array of context messages
  correction      String   // Admin's correction/explanation
  createdAt       DateTime @default(now())

  @@index([instanceId])
  @@index([createdAt])
}

model DailyStats {
  id              String   @id @default(uuid())
  instanceId      String   @default("default")
  date            DateTime // Date representing the specific day (e.g. at midnight)

  totalChats      Int      // Encompasses total users/chats in memory before clearing
  completedOrders Int      // Number of completed orders for the day
  totalRevenue    Float    // Total revenue for the day
  stepCounts      String?  // JSON: users per step at snapshot time (funnel analytics)

  createdAt       DateTime @default(now())

  @@unique([instanceId, date])
}

// --- Multi-tenant: Accounts & Sessions ---

model Account {
  id                 String   @id @default(uuid())
  name               String   @unique            // "nombre de usuario" — used for login
  password           String   // bcrypt hash
  role               String   @default("seller") // "admin" | "seller"
  sellerId           String?  @unique            // maps to instanceId; null for admin-only accounts
  isActive           Boolean  @default(true)
  totalOnlineSeconds Int      @default(0)        // cumulative seconds with the dashboard open
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sessions           AccountSession[]

  @@index([role])
}

// One row per "online span" = from when at least one socket for this account
// went online until all of them disconnected/went idle. Feeds the stats view
// (horas por día, mapa de calor, totales).
model AccountSession {
  id              String   @id @default(uuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int

  @@index([accountId, startedAt])
  @@index([startedAt])
}

model FunnelEvent {
  id           String   @id @default(uuid())
  sellerId     String
  phone        String
  stepFrom     String?                       // null = first step (greeting)
  stepTo       String
  enteredAt    DateTime @default(now())
  exitedAt     DateTime?
  exitType     String?                        // advanced | back | paused | dropped | completed
  messageCount Int      @default(0)
  aiCallCount  Int      @default(0)

  @@index([sellerId, enteredAt])
  @@index([sellerId, stepTo])
  @@index([phone, sellerId])
  @@index([sellerId, exitedAt])
}

model MessageEvent {
  id             String   @id @default(uuid())
  sellerId       String
  phone          String
  step           String
  at             DateTime @default(now())
  matched        Boolean  @default(false)     // el step handler matchó sin IA
  priceObjection Boolean  @default(false)     // Fase 3
  retryIndex     Int      @default(0)         // repetición # dentro del step

  @@index([sellerId, at])
  @@index([sellerId, step, at])
}

model WhatsAppSession {
  sellerId    String   @id              // matches instanceId across all tables
  status      String   @default("disconnected") // disconnected | qr_pending | connected
  phoneNumber String?  // connected WhatsApp phone number
  lastSeen    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuickReply {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  title       String
  message     String
  createdAt   DateTime @default(now())

  @@index([instanceId])
  @@unique([instanceId, title])
}

// Comentarios sobre los guiones (V3/V4/V5/V6) — los vendedores anotan
// correcciones, notas o preguntas sobre secciones específicas. Los admins
// pueden resolverlos o eliminarlos. sectionPath es un identificador estable
// como "flow.greeting", "flow.recommendation_1" o "faq[2]".
model GuionComment {
  id            String   @id @default(uuid())
  script        String                          // v3 | v4 | v5 | v6
  sectionPath   String                          // e.g. "flow.greeting", "faq[0]"
  type          String   @default("note")       // note | correction | question
  authorId      String                          // accountId del autor
  authorName    String                          // cached para mostrar
  content       String                          // texto del comentario
  suggestedText String?                         // (opcional) texto que sugiere para reemplazar la sección — solo correcciones
  reactions     String   @default("[]")         // JSON array of {accountId, name, emoji}
  resolved      Boolean  @default(false)        // marcado como resuelto por admin
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([script])
  @@index([script, sectionPath])
  @@index([resolved])
}

// API tokens for programmatic access (e.g. external Claude Code reading analytics).
// We store sha256(token) — never plaintext. The full token is shown to the
// admin once at creation time. `scopes` is a CSV of allowed scopes
// (currently only "analytics:read"). Revocation is soft via revokedAt.
model ApiToken {
  id          String    @id @default(uuid())
  name        String                       // human description, e.g. "Hermano - meta ads"
  tokenHash   String    @unique            // sha256 of the raw token
  prefix      String                       // first 8 chars of the token, for UI display
  scopes      String                       // csv: "analytics:read"
  createdById String                       // accountId who created it
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  @@index([revokedAt])
}

// Semantic cache: stores FAQ-style bot responses keyed by embedding similarity.
// The embedding is persisted as JSON-serialized Float[] in a Text column so
// Postgres native vector support isn't required. Cosine similarity is computed
// in-process over a small per-step candidate window.
model AiSemanticCache {
  id          String   @id @default(uuid())
  step        String   // e.g. "waiting_preference", "waiting_ok"
  userText    String   // raw (lowercased) user message — kept for debug
  embedding   String   // JSON Float[] (1536 dims for text-embedding-3-small)
  response    String   // bot response to serve verbatim
  hits        Int      @default(0)
  createdAt   DateTime @default(now())
  lastHit     DateTime @default(now())

  @@index([step])
  @@index([lastHit])
}
