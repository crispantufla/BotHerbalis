generator client {
  provider = "prisma-client-js"
}

// Para desarrollo local podemos usar SQLite para probar, pero luego Postgres.
// Dado que la app ya usa Railway y pide Postgres, usaremos postgresql.
datasource db {
  provider = "postgresql"
}

model User {
  phone       String
  instanceId  String   @default("default")
  name        String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now()) // Updated every time the user sends a message
  profileData String?  // Extracted by AI (e.g., weight goals, allergies)
  pausedAt    DateTime? // Set when bot auto-pauses this user
  pauseReason String?   // Human-readable reason for the pause

  orders      Order[]
  chats       ChatLog[]

  @@id([phone, instanceId])
}

model Order {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId], onDelete: Cascade)

  status      String   @default("Pendiente") // Pendiente, Confirmado, Enviado...
  products    String   // List of products bought
  totalPrice  Float
  tracking    String?
  postdated   String?
  seller      String?  // Phone number of the WhatsApp session that created the order

  nombre      String?
  calle       String?
  calleOriginal String?  // Raw address as typed by the client (before Maps formatting)
  ciudad      String?
  provincia   String?
  cp          String?

  createdAt   DateTime @default(now())

  @@index([userPhone])
  @@index([instanceId])
  @@index([createdAt])
}

model ChatLog {
  id          String   @id @default(uuid())
  instanceId  String   @default("default")
  userPhone   String
  user        User     @relation(fields: [userPhone, instanceId], references: [phone, instanceId], onDelete: Cascade)

  role        String   // "user" or "bot" or "system"
  content     String

  timestamp   DateTime @default(now())

  @@index([userPhone])
  @@index([timestamp])
}

model BotConfig {
  instanceId  String   @default("default")
  key         String   // e.g. "activeScript", "alertNumbers"
  value       String   // JSON stringified value

  @@id([instanceId, key])
}

model DailyStats {
  id              String   @id @default(uuid())
  instanceId      String   @default("default")
  date            DateTime // Date representing the specific day (e.g. at midnight)
  
  totalChats      Int      // Encompasses total users/chats in memory before clearing
  completedOrders Int      // Number of completed orders for the day
  totalRevenue    Float    // Total revenue for the day
  stepCounts      String?  // JSON: users per step at snapshot time (funnel analytics)

  createdAt       DateTime @default(now())

  @@unique([instanceId, date])
}
